# Keeps formatting consistent across editors and prevents the kind of
# silent-encoding-strip that drops UTF-8 emoji from Markdown tables.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yaml,yml,json}]
indent_size = 2

[*.md]
# Two trailing spaces are a deliberate hard line-break in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
